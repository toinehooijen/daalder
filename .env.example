# --- required -----------------------------------------------------------------

# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABCDEF-your-bot-token

# postgresql://user:password@host:5432/daalder
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/daalder

# --- LLM price-extraction fallback (Tier 3) -------------------------------------

ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Telegram Stars payments -----------------------------------------------------

# Amounts in Telegram Stars (XTR). ~150 Stars ≈ €2, ~900 Stars ≈ €12.
# Check the live Stars-to-EUR conversion before launch and tune these.
MONTHLY_STARS=150
ANNUAL_STARS=900

# Your own Telegram numeric user id. Used for /refund and error pings.
ADMIN_USER_ID=123456789

# --- scheduling (all optional, shown with defaults) ------------------------------

FREE_CHECK_INTERVAL_HOURS=24
PLUS_CHECK_INTERVAL_HOURS=4
SCHEDULER_INTERVAL_MINUTES=30
LAPSE_CHECK_INTERVAL_HOURS=24
RENEWAL_REMINDER_DAYS_BEFORE=7

# Politeness: minimum seconds between two requests to the same domain, plus
# up to this many extra seconds of random jitter, and the max number of
# checks running concurrently across all domains.
PER_DOMAIN_MIN_INTERVAL_SECONDS=5
PER_DOMAIN_JITTER_SECONDS=4
MAX_CONCURRENT_CHECKS=5

# --- browser fallback: anti-bot seam (all optional, shown with defaults) ---------

# Retries a blocked fetch (403/429/JS challenge) through headless Chromium.
# Set to false to disable and keep the old single-attempt httpx behavior.
ENABLE_BROWSER_FALLBACK=true
BROWSER_TIMEOUT_SECONDS=20

# How long (seconds) to keep polling for a client-side JS challenge to clear
# after the page loads, before giving up as blocked.
BROWSER_CHALLENGE_WAIT_SECONDS=8

# Optional proxy for the headless browser (e.g. a residential-proxy provider),
# e.g. http://user:pass@proxy-host:port. Leave empty to connect directly.
SCRAPE_PROXY_URL=

# --- search fallback: Claude web_search tool, Tier 4 (all optional) --------------

# When a site blocks scraping entirely, ask Claude to search the web for the
# current price instead of giving up. Uses the same ANTHROPIC_API_KEY above.
ENABLE_SEARCH_FALLBACK=true
ANTHROPIC_SEARCH_MODEL=claude-haiku-4-5-20251001
WEB_SEARCH_TOOL_TYPE=web_search_20250305
SEARCH_FALLBACK_MAX_USES=3

# --- store discovery: find other stores via search, Daalder Plus perk -----------

ENABLE_STORE_DISCOVERY=true
STORE_DISCOVERY_PLUS_ONLY=true
STORE_DISCOVERY_MAX_CANDIDATES=5
STORE_DISCOVERY_MAX_TOTAL=5
STORE_DISCOVERY_COOLDOWN_HOURS=24
